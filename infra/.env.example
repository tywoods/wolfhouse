# Copy to infra/.env for local docker compose (never commit real secrets)

# --- Wolfhouse app Postgres ---
WOLFHOUSE_DB_USER=wolfhouse
WOLFHOUSE_DB_PASSWORD=change_me_wolfhouse_db
WOLFHOUSE_DB_NAME=wolfhouse
WOLFHOUSE_DB_PORT=5433
WOLFHOUSE_DATABASE_URL=postgres://wolfhouse:change_me_wolfhouse_db@localhost:5433/wolfhouse

# --- n8n internal Postgres (workflows, credentials, execution history) ---
N8N_DB_USER=n8n
N8N_DB_PASSWORD=change_me_n8n_db
N8N_DB_NAME=n8n
N8N_DB_PORT=5434

# --- Redis (n8n queue mode) ---
REDIS_PORT=6379

# --- n8n ---
N8N_PORT=5678
N8N_HOST=localhost
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change_me_to_random_32_plus_chars
TZ=Europe/Madrid

# --- External integrations (configure in n8n credentials UI) ---
# AIRTABLE_API_TOKEN=
# ANTHROPIC_API_KEY=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# Phase 2d local Send Confirmation — default dry-run (no Graph API). Set false + tokens to send real test messages.
WHATSAPP_DRY_RUN=true
# Phase 2f — optional resolver audit (off by default; never blocks flow)
PHASE2F_LOG_WORKFLOW_EVENTS=false
# Stripe (Phase 2b local test — pass into n8n container, see docs/PHASE-2b.md)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me_from_stripe_listen
STRIPE_DEFAULT_DEPOSIT_CENTS=20000
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5678/webhook/stripe-checkout-success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5678/stripe-test-cancel
# Local dev only: true when n8n parses webhook JSON (signature verify impossible). Production MUST be false.
STRIPE_WEBHOOK_SKIP_VERIFY=false
# Phase 2c — local Main fork calls Create Payment Session
USE_STRIPE_CHECKOUT=true
N8N_CREATE_PAYMENT_SESSION_URL=http://localhost:5678/webhook/create-payment-session
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=

# Apps Script → n8n (shared header validation)
N8N_WEBHOOK_SHARED_SECRET=change_me_shared_secret

# Google Sheets planning workbook
GOOGLE_SHEETS_SPREADSHEET_ID=1eISph-eVZpylAEFVRS22hxRvWydBj07vz6G-vO7T_cc

# Airtable (dual-write phase)
AIRTABLE_BASE_ID=appOCWIN47Bui9CSS
