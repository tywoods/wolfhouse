FROM node:22-alpine

WORKDIR /app

ENV NODE_ENV=production
ENV STAFF_QUERY_API_PORT=3036
ENV STAFF_QUERY_API_HOST=0.0.0.0

COPY package*.json ./
RUN npm ci --omit=dev

COPY scripts ./scripts
COPY database ./database
COPY config ./config

# Sunset isolated staging: explicit Sunset-only portal access (no all_clients_emails).
RUN cp config/clients/staff-portal-access.sunset-staging.json config/clients/staff-portal-access.json \
 && node -e "const j=JSON.parse(require('fs').readFileSync('config/clients/staff-portal-access.json','utf8')); if((j.all_clients_emails||[]).length) { console.error('Sunset overlay must clear all_clients_emails'); process.exit(1); }"

EXPOSE 3036

CMD ["npm", "run", "staff:api"]
