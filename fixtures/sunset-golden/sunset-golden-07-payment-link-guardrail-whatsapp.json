        "reply_not_contains": ["http", "stripe.com", "pay.", "checkout"],
        "expected_no_payment_link": true,
        "expected_no_handoff": true
      }
    }
  ],
  "final_expect": {
    "no_payment_link": true,
    "no_invented_payment_link": true,
    "tenant_isolation": "sunset_only"
