          "asks_one_next_question": true,
          "next_question_about": ["duration", "pickup_time", "start_date"],
          "inventory_model": "unlimited",
          "must_not": [
            "payment_link",
            "invented_availability",
            "booking_confirmed",
            "wolfhouse_facts"
          ]
        },
        "reply_not_contains": ["http", "stripe", "pay.", "Wolfhouse", "Somo", "Malibu"],
        "expected_no_payment_link": true,
        "expected_no_handoff": true
      }
    }
  ],
  "final_expect": {
    "no_payment_link": true,
    "no_confirmation": true,
    "tenant_isolation": "sunset_only"
