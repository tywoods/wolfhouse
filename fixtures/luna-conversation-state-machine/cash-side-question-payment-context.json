{
  "id": "cash-side-question-payment-context",
  "label": "Cash side question preserves payment context",
  "contact_name": "Marco",
  "reference_date": "2026-06-10",
  "turns": [
    {
      "message": "July 1-5 for 1",
      "expect": {
        "expected_fields": {
          "check_in": "2026-07-01",
          "check_out": "2026-07-05",
          "guest_count": 1
        },
        "expected_no_handoff": true,
        "no_internal_language": true
      }
    },
    {
      "message": "no thanks, I have my own stuff",
      "expect": {
        "expected_quote_ready": true,
        "reply_contains": ["€180"],
        "expected_no_handoff": true,
        "no_internal_language": true
      }
    },
    {
      "message": "can I pay cash?",
      "expect": {
        "reply_contains": ["cash"],
        "expected_context_preserved": true,
        "expected_stale_quote": false,
        "expected_quote_ready": true,
        "expected_fields": {
          "check_in": "2026-07-01",
          "check_out": "2026-07-05",
          "guest_count": 1
        },
        "expected_no_handoff": true,
        "no_internal_language": true
      }
    },
    {
      "message": "deposit",
      "expect": {
        "expected_payment_choice": "deposit",
        "expected_quote_ready": true,
        "expected_no_handoff": true,
        "no_internal_language": true
      }
    }
  ],
  "final_expect": {
    "expected_fields": {
      "check_in": "2026-07-01",
      "check_out": "2026-07-05",
      "guest_count": 1,
      "package_interest": "accommodation_only"
    },
    "expected_payment_choice": "deposit",
    "expected_quote_ready": true,
    "no_internal_language": true,
    "no_handoff": true
  }
}
