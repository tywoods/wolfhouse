{
  "id": "package-side-question-mid-flow",
  "label": "Package side-question mid-flow to deposit",
  "contact_name": "Marco",
  "reference_date": "2026-06-10",
  "turns": [
    { "message": "hi" },
    { "message": "book a stay" },
    { "message": "July 10-17" },
    { "message": "1",
      "expect": {
        "reply_contains": ["Malibu", "Uluwatu", "Waimea"],
        "expected_reply_source": "luna_reply_composer",
        "expected_composer_state": "ask_package_choice",
        "no_form_dev_copy": true,
        "reply_not_contains": ["I am not confirming", "I am not adding"],
        "expected_fields": {
          "check_in": "2026-07-10",
          "check_out": "2026-07-17",
          "guest_count": 1
        },
        "expected_no_handoff": true
      }
    },
    {
      "message": "explain the packages",
      "expect": {
        "reply_contains": ["Malibu", "Uluwatu", "Waimea", "July"],
        "expected_reply_source": "luna_reply_composer",
        "expected_composer_state": "explain_packages",
        "no_form_dev_copy": true,
        "expected_fields": {
          "check_in": "2026-07-10",
          "check_out": "2026-07-17",
          "guest_count": 1
        },
        "expected_no_handoff": true
      }
    },
    {
      "message": "Malibu",
      "expect": {
        "expected_fields": {
          "package_interest": "malibu",
          "guest_count": 1,
          "check_in": "2026-07-10",
          "check_out": "2026-07-17"
        },
        "expected_quote_ready": true,
        "reply_contains": ["wetsuit", "lessons"],
        "expected_no_handoff": true
      }
    },
    {
      "message": "just the stay",
      "expect": {
        "expected_no_handoff": true,
        "expected_quote_ready": true
      }
    },
    {
      "message": "deposit",
      "expect": {
        "expected_payment_choice": "deposit",
        "expected_no_handoff": true
      }
    }
  ],
  "final_expect": {
    "confirmation_sent": false,
    "no_internal_language": true,
    "no_form_dev_copy": true,
    "expected_final_reply_source": "luna_reply_composer",
    "no_handoff": true,
    "expected_fields": {
      "guest_count": 1,
      "package_interest": "malibu",
      "check_in": "2026-07-10",
      "check_out": "2026-07-17"
    },
    "expected_payment_choice": "deposit",
    "expected_quote_ready": true
  }
}
