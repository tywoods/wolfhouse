{
  "id": "italian-guest-count-correction-invalidates-quote",
  "fixture_set": "hammer-regressions",
  "language": "it",
  "label": "Italian guest-count correction invalidates quote",
  "contact_name": "Marco",
  "reference_date": "2026-06-10",
  "turns": [
    {
      "message": "1-5 luglio per 1",
      "expect": {
        "expected_fields": {
          "check_in": "2026-07-01",
          "check_out": "2026-07-05",
          "guest_count": 1
        },
        "expected_quote_ready": true,
        "expected_no_handoff": true,
        "no_internal_language": true,
        "allow_partial": true
      }
    },
    {
      "message": "no thanks, solo alloggio",
      "expect": {
        "expected_quote_ready": true,
        "expected_accommodation_only": true,
        "expected_no_handoff": true,
        "no_internal_language": true,
        "allow_partial": true
      }
    },
    {
      "message": "in realtà siamo 3",
      "expect": {
        "expected_guest_count": 3,
        "expected_stale_quote": true,
        "expected_stale_quote_reason": "guest_count_changed",
        "expected_corrected_fields": ["guest_count"],
        "expected_quote_ready": true,
        "expected_no_handoff": true,
        "no_internal_language": true,
        "allow_partial": true
      }
    }
  ],
  "final_expect": {
    "expected_fields": {
      "check_in": "2026-07-01",
      "check_out": "2026-07-05",
      "guest_count": 3,
      "package_interest": "accommodation_only"
    },
    "expected_quote_ready": true,
    "no_internal_language": true,
    "no_handoff": true
  }
}
