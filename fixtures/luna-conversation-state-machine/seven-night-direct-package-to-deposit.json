{
  "id": "seven-night-direct-package-to-deposit",
  "label": "Seven-night direct Malibu package to deposit",
  "contact_name": "Marco",
  "reference_date": "2026-06-10",
  "turns": [
    {
      "message": "Malibu July 10 to July 17 for 1",
      "expect": {
        "reply_not_contains": ["grab your name", "your name for the booking"],
        "expected_fields": {
          "guest_count": 1,
          "package_interest": "malibu",
          "check_in": "2026-07-10",
          "check_out": "2026-07-17"
        },
        "expected_quote_ready": true,
        "expected_no_handoff": true
      }
    },
    {
      "message": "deposit",
      "expect": {
        "expected_payment_choice": "deposit",
        "expected_no_handoff": true,
        "reply_contains": ["deposit"]
      }
    }
  ],
  "final_expect": {
    "confirmation_sent": false,
    "no_internal_language": true,
    "no_handoff": true,
    "expected_fields": {
      "guest_count": 1,
      "package_interest": "malibu"
    },
    "expected_payment_choice": "deposit",
    "expected_quote_ready": true
  },
  "write_expect": {
    "booking_created": true,
    "booking_code_exists": true,
    "payment_draft_created": true,
    "payment_draft_id_exists": true,
    "stripe_test_checkout_created": "optional",
    "stripe_live_used": false,
    "confirmation_sent": false,
    "duplicate_booking_created": false,
    "cleanup_expected": true,
    "expected_deposit_cents": 20000,
    "idempotency_check": true,
    "assigned_beds_count": 1,
    "no_operator_blocked_beds": true,
    "no_inactive_beds": true,
    "assigned_priority_order": "ascending"
  },
  "webhook_expect": {
    "expected_payment_status_after_webhook": "deposit_paid",
    "expected_amount_paid_cents": 20000,
    "expected_confirmation_sent": false,
    "expected_confirmation_sent_at_unchanged": true,
    "expected_no_duplicate_payment_truth": true,
    "expected_webhook_idempotency": true,
    "cleanup_refused_expected": true
  }
}
